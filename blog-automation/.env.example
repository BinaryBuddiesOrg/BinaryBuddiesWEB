# API Keys (REQUIRED)
# Get OpenRouter key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Get SerpAPI key from: https://serpapi.com/manage-api-key
SERPAPI_API_KEY=your-serpapi-api-key-here

# Generate Odoo API key: openssl rand -hex 32
ODOO_BLOG_API_KEY=your-odoo-blog-api-key-here

# Odoo Configuration
ODOO_URL=http://localhost:8069

# Automation Settings
MAX_BLOGS_PER_RUN=30
POST_INTERVAL_HOURS=24

# LLM Configuration
# Examples: openai/gpt-4o, anthropic/claude-3.5-sonnet, meta-llama/llama-3.1-70b-instruct
LLM_MODEL=openai/gpt-4o

# SERP Configuration
SERP_SEARCH_QUERY=AI automation trends

# Author Settings
AUTHOR_NAME=AI Content Bot
AUTHOR_AVATAR=AI

# Logging
LOG_LEVEL=INFO
