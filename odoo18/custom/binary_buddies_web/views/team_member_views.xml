<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_bbweb_team_member_tree" model="ir.ui.view">
        <field name="name">bbweb.team.member.tree</field>
        <field name="model">bbweb.team.member</field>
        <field name="arch" type="xml">
            <list string="Team Members">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="role"/>
                <field name="specialty"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_bbweb_team_member_form" model="ir.ui.view">
        <field name="name">bbweb.team.member.form</field>
        <field name="model">bbweb.team.member</field>
        <field name="arch" type="xml">
            <form string="Team Member">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    </div>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <group>
                        <group>
                            <field name="name" placeholder="Full Name"/>
                            <field name="role" placeholder="e.g., CEO &amp; Co-Founder"/>
                            <field name="specialty" placeholder="e.g., AI Strategy &amp; Vision"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="linkedin_url" widget="url" placeholder="https://linkedin.com/in/..."/>
                            <field name="github_url" widget="url" placeholder="https://github.com/..."/>
                            <field name="twitter_url" widget="url" placeholder="https://twitter.com/..."/>
                            <field name="image_filename" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="bio" placeholder="Brief biography..."/>
                    </group>
                    <notebook>
                        <page string="Certifications" name="certifications">
                            <field name="certification_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name" placeholder="e.g., AWS Solutions Architect"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_bbweb_team_member_search" model="ir.ui.view">
        <field name="name">bbweb.team.member.search</field>
        <field name="model">bbweb.team.member</field>
        <field name="arch" type="xml">
            <search string="Search Team Members">
                <field name="name"/>
                <field name="role"/>
                <field name="specialty"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Role" name="group_role" context="{'group_by': 'role'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_bbweb_team_member" model="ir.actions.act_window">
        <field name="name">Team Members</field>
        <field name="res_model">bbweb.team.member</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first team member
            </p>
            <p>
                Showcase your talented team members on the website.
            </p>
        </field>
    </record>
</odoo>
