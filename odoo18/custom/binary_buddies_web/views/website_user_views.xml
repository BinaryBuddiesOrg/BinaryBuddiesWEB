<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Website User List View -->
    <record id="view_website_user_tree" model="ir.ui.view">
        <field name="name">bbweb.website.user.list</field>
        <field name="model">bbweb.website.user</field>
        <field name="arch" type="xml">
            <list string="Website Users" decoration-danger="is_banned == True">
                <field name="name"/>
                <field name="email"/>
                <field name="login_count"/>
                <field name="last_login"/>
                <field name="is_banned"/>
                <field name="can_comment"/>
                <field name="can_author_blogs"/>
            </list>
        </field>
    </record>


    <!-- Website User Form View -->
    <record id="view_website_user_form" model="ir.ui.view">
        <field name="name">bbweb.website.user.form</field>
        <field name="model">bbweb.website.user</field>
        <field name="arch" type="xml">
            <form string="Website User">
                <header>
                    <button name="action_ban_user" string="Ban User" type="object" 
                            class="btn-danger" invisible="is_banned == True"/>
                    <button name="action_unban_user" string="Unban User" type="object"
                            class="btn-success" invisible="is_banned == False"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget name="web_ribbon" title="Banned" bg_color="bg-danger"
                            invisible="is_banned == False"/>
                    <field name="image_url" widget="image_url" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="User Name"/>
                        </h1>
                        <h3>
                            <field name="email" placeholder="email@example.com"/>
                        </h3>
                    </div>
                    <group>
                        <group string="Google OAuth">
                            <field name="google_id" readonly="1"/>
                            <field name="image_url" readonly="1"/>
                        </group>
                        <group string="Statistics">
                            <field name="first_login" readonly="1"/>
                            <field name="last_login" readonly="1"/>
                            <field name="login_count" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Permissions">
                            <field name="can_comment"/>
                            <field name="can_author_blogs"/>
                        </group>
                        <group string="Status">
                            <field name="active"/>
                            <field name="is_banned"/>
                            <field name="ban_reason" invisible="is_banned == False"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Website User Search View -->
    <record id="view_website_user_search" model="ir.ui.view">
        <field name="name">bbweb.website.user.search</field>
        <field name="model">bbweb.website.user</field>
        <field name="arch" type="xml">
            <search string="Search Website Users">
                <field name="name"/>
                <field name="email"/>
                <filter name="active" string="Active" domain="[('active', '=', True)]"/>
                <filter name="banned" string="Banned" domain="[('is_banned', '=', True)]"/>
                <filter name="can_author" string="Can Author Blogs" domain="[('can_author_blogs', '=', True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Banned Status" name="group_by_banned" context="{'group_by': 'is_banned'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Website User Action -->
    <record id="action_website_user" model="ir.actions.act_window">
        <field name="name">Website Users</field>
        <field name="res_model">bbweb.website.user</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_website_user_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No website users yet!
            </p>
            <p>
                Website users are automatically created when visitors sign in with Google.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_website_user" 
              name="Website Users" 
              parent="menu_bbweb_root" 
              action="action_website_user"
              sequence="90"/>
</odoo>
