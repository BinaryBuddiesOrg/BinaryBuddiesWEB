# =============================================================================
# ODOO ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
ODOO_DB_PASSWORD=your_secure_password_here

# -----------------------------------------------------------------------------
# AWS S3 Configuration
# -----------------------------------------------------------------------------
# IAM User Credentials (create user with S3 access only)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# S3 Bucket Configuration
AWS_S3_BUCKET=binarybuddies-attachments
AWS_S3_REGION=ap-south-1

# -----------------------------------------------------------------------------
# CloudFront Configuration
# -----------------------------------------------------------------------------
# CloudFront Distribution Domain (without https://)
CLOUDFRONT_DOMAIN=d1234abcdef.cloudfront.net

# -----------------------------------------------------------------------------
# Odoo Admin (optional)
# -----------------------------------------------------------------------------
# ODOO_ADMIN_PASSWORD=your_admin_password
