    <record id="career_fullstack" model="bbweb.career">
        <field name="title">Senior Full Stack Developer</field>
        <field name="department">Engineering</field>
        <field name="location">Remote</field>
        <field name="employment_type">full_time</field>
        <field name="description">We're seeking an experienced Full Stack Developer to join our engineering team and help build cutting-edge AI-powered applications.</field>
        <field name="sequence">10</field>
