    <!-- Featured Project 1: AI-Powered Healthcare Platform -->
    <record id="project_healthcare" model="bbweb.featured.project">
        <field name="name">AI-Powered Healthcare Platform</field>
        <field name="category">Healthcare</field>
        <field name="description">Revolutionized patient care with predictive analytics and automated diagnosis assistance.</field>
        <field name="gradient">from-primary/20 to-accent/20</field>
        <field name="tag_ids" eval="[(6, 0, [ref('tag_ai'), ref('tag_ml'), ref('tag_healthcare')])]"/>
        <field name="sequence">10</field>
    </record>
    <record id="project_healthcare_result1" model="bbweb.project.result">
        <field name="project_id" ref="project_healthcare"/>
        <field name="result">50% faster diagnosis</field>
        <field name="sequence">1</field>
    </record>
    <record id="project_healthcare_result2" model="bbweb.project.result">
        <field name="project_id" ref="project_healthcare"/>
        <field name="result">98% accuracy rate</field>
        <field name="sequence">2</field>
    </record>
    <record id="project_healthcare_result3" model="bbweb.project.result">
        <field name="project_id" ref="project_healthcare"/>
        <field name="result">500+ hospitals</field>
        <field name="sequence">3</field>
    </record>

