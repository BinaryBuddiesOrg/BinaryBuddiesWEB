<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Blog Comment List View -->
    <record id="view_blog_comment_tree" model="ir.ui.view">
        <field name="name">bbweb.blog.comment.list</field>
        <field name="model">bbweb.blog.comment</field>
        <field name="arch" type="xml">
            <list string="Blog Comments" decoration-muted="is_deleted == True">
                <field name="blog_id"/>
                <field name="user_id"/>
                <field name="content" widget="text"/>
                <field name="parent_id"/>
                <field name="depth"/>
                <field name="like_count"/>
                <field name="reply_count"/>
                <field name="is_edited"/>
                <field name="is_deleted"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <!-- Blog Comment Form View -->
    <record id="view_blog_comment_form" model="ir.ui.view">
        <field name="name">bbweb.blog.comment.form</field>
        <field name="model">bbweb.blog.comment</field>
        <field name="arch" type="xml">
            <form string="Blog Comment">
                <sheet>
                    <widget name="web_ribbon" title="Deleted" bg_color="bg-danger"
                            invisible="is_deleted == False"/>
                    <group>
                        <group string="Comment Details">
                            <field name="blog_id"/>
                            <field name="user_id"/>
                            <field name="parent_id"/>
                            <field name="depth" readonly="1"/>
                        </group>
                        <group string="Statistics">
                            <field name="like_count" readonly="1"/>
                            <field name="reply_count" readonly="1"/>
                            <field name="is_edited" readonly="1"/>
                            <field name="edited_at" readonly="1" invisible="is_edited == False"/>
                        </group>
                    </group>
                    <separator string="Content"/>
                    <field name="content"/>
                    <group>
                        <group string="Status">
                            <field name="is_deleted"/>
                            <field name="deleted_at" readonly="1" invisible="is_deleted == False"/>
                            <field name="active"/>
                        </group>
                        <group string="Timestamps">
                            <field name="create_date" readonly="1"/>
                        </group>
                    </group>
                    <separator string="Replies"/>
                    <field name="child_ids" readonly="1">
                        <list>
                            <field name="user_id"/>
                            <field name="content"/>
                            <field name="like_count"/>
                            <field name="create_date"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Blog Comment Search View -->
    <record id="view_blog_comment_search" model="ir.ui.view">
        <field name="name">bbweb.blog.comment.search</field>
        <field name="model">bbweb.blog.comment</field>
        <field name="arch" type="xml">
            <search string="Search Comments">
                <field name="content"/>
                <field name="user_id"/>
                <field name="blog_id"/>
                <filter name="active" string="Active" domain="[('active', '=', True)]"/>
                <filter name="deleted" string="Deleted" domain="[('is_deleted', '=', True)]"/>
                <filter name="root_comments" string="Root Comments" domain="[('parent_id', '=', False)]"/>
                <filter name="replies" string="Replies" domain="[('parent_id', '!=', False)]"/>
                <separator/>
                <filter name="has_likes" string="Has Likes" domain="[('like_count', '>', 0)]"/>
                <filter name="has_replies" string="Has Replies" domain="[('reply_count', '>', 0)]"/>
                <group expand="0" string="Group By">
                    <filter string="Blog Post" name="group_by_blog" context="{'group_by': 'blog_id'}"/>
                    <filter string="User" name="group_by_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Date" name="group_by_date" context="{'group_by': 'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Blog Comment Action -->
    <record id="action_blog_comment" model="ir.actions.act_window">
        <field name="name">Blog Comments</field>
        <field name="res_model">bbweb.blog.comment</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_blog_comment_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No comments yet!
            </p>
            <p>
                Comments will appear here when users comment on blog posts.
            </p>
        </field>
    </record>
</odoo>
