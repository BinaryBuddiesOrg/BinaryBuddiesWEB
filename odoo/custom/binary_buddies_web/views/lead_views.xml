<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bbweb_lead_form" model="ir.ui.view">
        <field name="name">bbweb.lead.form</field>
        <field name="model">bbweb.lead</field>
        <field name="arch" type="xml">
            <form string="Website Lead">
                <header>
                    <field name="status" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="first_name"/>
                            <field name="last_name"/>
                            <field name="email"/>
                            <field name="phone"/>
                        </group>
                        <group>
                            <field name="service"/>
                            <field name="create_date" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Project Details">
                            <field name="project_details"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_bbweb_lead_tree" model="ir.ui.view">
        <field name="name">bbweb.lead.list</field>
        <field name="model">bbweb.lead</field>
        <field name="arch" type="xml">
            <list string="Website Leads" decoration-info="status == 'open'" decoration-muted="status == 'closed'">
                <field name="create_date"/>
                <field name="first_name"/>
                <field name="last_name"/>
                <field name="email"/>
                <field name="service"/>
                <field name="status" widget="badge" decoration-success="status == 'open'" decoration-muted="status == 'closed'"/>
            </list>
        </field>
    </record>

    <record id="action_bbweb_leads" model="ir.actions.act_window">
        <field name="name">Website Leads</field>
        <field name="res_model">bbweb.lead</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No leads found.
            </p>
        </field>
    </record>
</odoo>
