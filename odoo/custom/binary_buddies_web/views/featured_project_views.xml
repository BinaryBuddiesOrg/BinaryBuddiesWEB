<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_bbweb_featured_project_tree" model="ir.ui.view">
        <field name="name">bbweb.featured.project.tree</field>
        <field name="model">bbweb.featured.project</field>
        <field name="arch" type="xml">
            <list string="Featured Projects">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="category"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_bbweb_featured_project_form" model="ir.ui.view">
        <field name="name">bbweb.featured.project.form</field>
        <field name="model">bbweb.featured.project</field>
        <field name="arch" type="xml">
            <form string="Featured Project">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    </div>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <group>
                        <group>
                            <field name="name" placeholder="e.g., AI-Powered Healthcare Platform"/>
                            <field name="category" placeholder="e.g., Healthcare, Retail, Finance"/>
                            <field name="gradient" placeholder="e.g., from-primary/20 to-accent/20"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="image_filename" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Brief description of the project..."/>
                    </group>
                    <notebook>
                        <page string="Results" name="results">
                            <field name="result_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="result" placeholder="e.g., 50% faster diagnosis"/>
                                </list>
                            </field>
                        </page>
                        <page string="Tags" name="tags">
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_bbweb_featured_project_search" model="ir.ui.view">
        <field name="name">bbweb.featured.project.search</field>
        <field name="model">bbweb.featured.project</field>
        <field name="arch" type="xml">
            <search string="Search Featured Projects">
                <field name="name"/>
                <field name="category"/>
                <field name="tag_ids"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Category" name="group_category" context="{'group_by': 'category'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_bbweb_featured_project" model="ir.actions.act_window">
        <field name="name">Featured Projects</field>
        <field name="res_model">bbweb.featured.project</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first featured project
            </p>
            <p>
                Showcase your best work with featured projects that will be displayed on the website.
            </p>
        </field>
    </record>

    <!-- Project Tag Views -->
    <record id="view_bbweb_project_tag_tree" model="ir.ui.view">
        <field name="name">bbweb.project.tag.tree</field>
        <field name="model">bbweb.project.tag</field>
        <field name="arch" type="xml">
            <list string="Project Tags" editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <record id="action_bbweb_project_tag" model="ir.actions.act_window">
        <field name="name">Project Tags</field>
        <field name="res_model">bbweb.project.tag</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
