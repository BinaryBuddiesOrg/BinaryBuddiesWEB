<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_bbweb_career_tree" model="ir.ui.view">
        <field name="name">bbweb.career.tree</field>
        <field name="model">bbweb.career</field>
        <field name="arch" type="xml">
            <list string="Career Listings">
                <field name="sequence" widget="handle"/>
                <field name="title"/>
                <field name="department"/>
                <field name="location"/>
                <field name="employment_type"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_bbweb_career_form" model="ir.ui.view">
        <field name="name">bbweb.career.form</field>
        <field name="model">bbweb.career</field>
        <field name="arch" type="xml">
            <form string="Career Listing">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    </div>
                    <group>
                        <group>
                            <field name="title" placeholder="Job Title"/>
                            <field name="department" placeholder="e.g., Engineering, Marketing"/>
                            <field name="location" placeholder="e.g., Remote, New York"/>
                        </group>
                        <group>
                            <field name="employment_type"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Job description..."/>
                    </group>
                    <notebook>
                        <page string="Requirements" name="requirements">
                            <field name="requirement_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="requirement" placeholder="e.g., 5+ years of experience..."/>
                                </list>
                            </field>
                        </page>
                        <page string="Responsibilities" name="responsibilities">
                            <field name="responsibility_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="responsibility" placeholder="e.g., Design and develop..."/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_bbweb_career_search" model="ir.ui.view">
        <field name="name">bbweb.career.search</field>
        <field name="model">bbweb.career</field>
        <field name="arch" type="xml">
            <search string="Search Career Listings">
                <field name="title"/>
                <field name="department"/>
                <field name="location"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Full-time" name="type_full_time" domain="[('employment_type', '=', 'full_time')]"/>
                <filter string="Remote" name="type_remote" domain="[('employment_type', '=', 'remote')]"/>
                <filter string="Hybrid" name="type_hybrid" domain="[('employment_type', '=', 'hybrid')]"/>
                <group expand="0" string="Group By">
                    <filter string="Department" name="group_department" context="{'group_by': 'department'}"/>
                    <filter string="Employment Type" name="group_type" context="{'group_by': 'employment_type'}"/>
                    <filter string="Location" name="group_location" context="{'group_by': 'location'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_bbweb_career" model="ir.actions.act_window">
        <field name="name">Career Listings</field>
        <field name="res_model">bbweb.career</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first career listing
            </p>
            <p>
                Post job openings that will be displayed on the careers page.
            </p>
        </field>
    </record>
</odoo>
