<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_bbweb_blog_post_tree" model="ir.ui.view">
        <field name="name">bbweb.blog.post.tree</field>
        <field name="model">bbweb.blog.post</field>
        <field name="arch" type="xml">
            <list string="Blog Posts">
                <field name="publish_date"/>
                <field name="title"/>
                <field name="slug"/>
                <field name="category"/>
                <field name="author_name"/>
                <field name="featured" widget="boolean_toggle"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_bbweb_blog_post_form" model="ir.ui.view">
        <field name="name">bbweb.blog.post.form</field>
        <field name="model">bbweb.blog.post</field>
        <field name="arch" type="xml">
            <form string="Blog Post">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                        <widget name="web_ribbon" title="Featured" bg_color="bg-success" invisible="not featured"/>
                    </div>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <group>
                        <group>
                            <field name="title" placeholder="Blog post title..."/>
                            <field name="slug" placeholder="URL-friendly slug (auto-generated from title)"/>
                            <field name="category"/>
                            <field name="publish_date"/>
                            <field name="read_time" placeholder="e.g., 8 min read"/>
                        </group>
                        <group>
                            <field name="author_name" placeholder="Author name"/>
                            <field name="author_avatar" placeholder="e.g., SC"/>
                            <field name="featured"/>
                            <field name="active"/>
                            <field name="image_filename" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="excerpt" placeholder="Short summary of the blog post..."/>
                    </group>
                    <group>
                        <field name="tag_ids" widget="many2many_tags" placeholder="Add tags..."/>
                    </group>
                    <notebook>
                        <page string="Content (Visual Editor)" name="content_visual">
                            <field name="content" widget="html" options="{'full': True, 'codeview': True, 'collaborative': False, 'sanitize': False, 'sanitize_tags': False}"/>
                            <div class="alert alert-warning mt-2" role="alert">
                                <strong>Note:</strong> Use the visual editor for formatting. For iframes/videos, use the "HTML Source" tab.
                            </div>
                        </page>
                        <page string="HTML Source (Advanced)" name="content_source">
                            <group>
                                <field name="content" widget="ace" options="{'mode': 'html'}"  nolabel="1"/>
                            </group>
                            <div class="alert alert-info mt-2" role="alert">
                                <strong>HTML Code Editor:</strong> Paste iframe codes and custom HTML here. Changes sync with the Visual Editor tab.
                            </div>
                        </page>
                        <page string="SEO Settings" name="seo">
                            <group>
                                <group string="SEO Metadata">
                                    <field name="seo_title" placeholder="Custom SEO title (defaults to title if empty)"/>
                                    <field name="seo_description" placeholder="Meta description for search engines (defaults to excerpt if empty)"/>
                                    <field name="seo_keywords" placeholder="Comma-separated keywords (e.g., AI, machine learning, automation)"/>
                                </group>
                                <group string="Social Media">
                                    <field name="og_image" widget="image" options="{'preview_image': 'image', 'size': [1024, 1024]}"/>
                                    <field name="og_image_filename" invisible="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_bbweb_blog_post_search" model="ir.ui.view">
        <field name="name">bbweb.blog.post.search</field>
        <field name="model">bbweb.blog.post</field>
        <field name="arch" type="xml">
            <search string="Search Blog Posts">
                <field name="title"/>
                <field name="author_name"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Featured" name="featured" domain="[('featured', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="AI/ML" name="category_ai_ml" domain="[('category', '=', 'ai_ml')]"/>
                <filter string="Automation" name="category_automation" domain="[('category', '=', 'automation')]"/>
                <filter string="Development" name="category_development" domain="[('category', '=', 'development')]"/>
                <filter string="Industry News" name="category_industry_news" domain="[('category', '=', 'industry_news')]"/>
                <group expand="0" string="Group By">
                    <filter string="Category" name="group_category" context="{'group_by': 'category'}"/>
                    <filter string="Author" name="group_author" context="{'group_by': 'author_name'}"/>
                    <filter string="Publish Date" name="group_publish_date" context="{'group_by': 'publish_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_bbweb_blog_post" model="ir.actions.act_window">
        <field name="name">Blog Posts</field>
        <field name="res_model">bbweb.blog.post</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first blog post
            </p>
            <p>
                Share insights and knowledge with blog posts that will be displayed on the website.
            </p>
        </field>
    </record>

    <!-- Blog Tag Views -->
    <record id="view_bbweb_blog_tag_tree" model="ir.ui.view">
        <field name="name">bbweb.blog.tag.tree</field>
        <field name="model">bbweb.blog.tag</field>
        <field name="arch" type="xml">
            <list string="Blog Tags" editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="view_bbweb_blog_tag_form" model="ir.ui.view">
        <field name="name">bbweb.blog.tag.form</field>
        <field name="model">bbweb.blog.tag</field>
        <field name="arch" type="xml">
            <form string="Blog Tag">
                <sheet>
                    <group>
                        <group>
                            <field name="name" placeholder="Tag name (e.g., AI, Machine Learning)"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                        <group>
                            <field name="description" placeholder="Optional description of the tag"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_bbweb_blog_tag" model="ir.actions.act_window">
        <field name="name">Blog Tags</field>
        <field name="res_model">bbweb.blog.tag</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
