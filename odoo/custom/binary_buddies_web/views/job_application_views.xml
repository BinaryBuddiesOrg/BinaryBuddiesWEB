<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_bbweb_job_application_tree" model="ir.ui.view">
        <field name="name">bbweb.job.application.tree</field>
        <field name="model">bbweb.job.application</field>
        <field name="arch" type="xml">
            <list string="Job Applications" default_order="applied_date desc">
                <field name="name"/>
                <field name="email"/>
                <field name="position_title"/>
                <field name="department"/>
                <field name="applied_date"/>
                <field name="status" widget="badge" decoration-info="status == 'new'" decoration-warning="status == 'reviewed'" decoration-success="status in ('interviewed', 'hired')" decoration-danger="status == 'rejected'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_bbweb_job_application_form" model="ir.ui.view">
        <field name="name">bbweb.job.application.form</field>
        <field name="model">bbweb.job.application</field>
        <field name="arch" type="xml">
            <form string="Job Application">
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="new,reviewed,interviewed,hired"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Applicant Name"/>
                        </h1>
                        <h3>
                            <field name="position_title" readonly="1"/>
                        </h3>
                    </div>
                    <group>
                        <group>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="career_id"/>
                        </group>
                        <group>
                            <field name="department" readonly="1"/>
                            <field name="applied_date"/>
                            <field name="resume" filename="resume_filename"/>
                            <field name="resume_filename" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Cover Letter" name="cover_letter">
                            <field name="cover_letter" placeholder="Applicant's cover letter..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_bbweb_job_application_search" model="ir.ui.view">
        <field name="name">bbweb.job.application.search</field>
        <field name="model">bbweb.job.application</field>
        <field name="arch" type="xml">
            <search string="Search Job Applications">
                <field name="name"/>
                <field name="email"/>
                <field name="position_title"/>
                <field name="department"/>
                <separator/>
                <filter string="New" name="new" domain="[('status', '=', 'new')]"/>
                <filter string="Reviewed" name="reviewed" domain="[('status', '=', 'reviewed')]"/>
                <filter string="Interviewed" name="interviewed" domain="[('status', '=', 'interviewed')]"/>
                <filter string="Hired" name="hired" domain="[('status', '=', 'hired')]"/>
                <filter string="Rejected" name="rejected" domain="[('status', '=', 'rejected')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Position" name="group_position" context="{'group_by': 'career_id'}"/>
                    <filter string="Department" name="group_department" context="{'group_by': 'department'}"/>
                    <filter string="Applied Date" name="group_date" context="{'group_by': 'applied_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_bbweb_job_application" model="ir.actions.act_window">
        <field name="name">Job Applications</field>
        <field name="res_model">bbweb.job.application</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_new': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No job applications yet
            </p>
            <p>
                Applications submitted through the website will appear here.
            </p>
        </field>
    </record>
</odoo>
