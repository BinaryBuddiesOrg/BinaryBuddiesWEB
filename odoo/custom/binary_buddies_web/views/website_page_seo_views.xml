<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_bbweb_website_page_seo_tree" model="ir.ui.view">
        <field name="name">bbweb.website.page.seo.tree</field>
        <field name="model">bbweb.website.page.seo</field>
        <field name="arch" type="xml">
            <list string="Website Page SEO">
                <field name="page_path"/>
                <field name="page_name"/>
                <field name="seo_title"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_bbweb_website_page_seo_form" model="ir.ui.view">
        <field name="name">bbweb.website.page.seo.form</field>
        <field name="model">bbweb.website.page.seo</field>
        <field name="arch" type="xml">
            <form string="Website Page SEO">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <widget name="web_ribbon" title="Inactive" bg_color="bg-danger" invisible="active"/>
                    </div>
                    <group>
                        <group>
                            <field name="page_path" placeholder="e.g., /, /services/web-development"/>
                            <field name="page_name" placeholder="e.g., Homepage, Web Development Services"/>
                            <field name="page_type"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="SEO Settings" name="seo">
                            <group>
                                <group string="SEO Metadata">
                                    <field name="seo_title" placeholder="Custom SEO title (defaults to page name if empty)"/>
                                    <field name="seo_description" placeholder="Meta description for search engines"/>
                                    <field name="seo_keywords" placeholder="Comma-separated keywords (e.g., web development, software, AI)"/>
                                </group>
                                <group string="Social Media">
                                    <field name="og_image" widget="image" options="{'preview_image': 'og_image', 'size': [1024, 1024]}"/>
                                    <field name="og_image_filename" invisible="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_bbweb_website_page_seo_search" model="ir.ui.view">
        <field name="name">bbweb.website.page.seo.search</field>
        <field name="model">bbweb.website.page.seo</field>
        <field name="arch" type="xml">
            <search string="Search Website Page SEO">
                <field name="page_path"/>
                <field name="page_name"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Inactive" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Page Type" name="group_page_type" context="{'group_by': 'page_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_bbweb_website_page_seo" model="ir.actions.act_window">
        <field name="name">Website Page SEO</field>
        <field name="res_model">bbweb.website.page.seo</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create SEO settings for a website page
            </p>
            <p>
                Manage SEO metadata (title, description, keywords, OG image) for main website pages.
                If a page doesn't have SEO settings here, the website will use default/hardcoded values.
            </p>
        </field>
    </record>
</odoo>
